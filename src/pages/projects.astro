---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import PortfolioGrid from '../components/PortfolioGrid.astro';
import Contact from '../components/Contact.astro';

const seoTitle = 'Featured UGC Campaigns & Creative Asset Grid';
const seoDescription = 'Browse through high-converting UGC video ads, product photography portfolios, and social-first creatives. Categorized views with direct lightboxes.';
---

<Layout title={seoTitle} description={seoDescription}>
  <Header />

  <main class="projects-page">
    <!-- Projects Page Hero -->
    <section class="projects-hero">
      <div class="container hero-content-wrapper">
        <h1 class="projects-title">Featured <span class="text-gradient">Campaigns</span></h1>
        <p class="projects-subtitle">Explore a collection of high-converting visual assets, customized hooks, and raw creative directions built for social platforms.</p>
      </div>
    </section>

    <!-- Portfolio Grid Component -->
    <PortfolioGrid />

    <!-- Direct Contact Details -->
    <Contact />
  </main>
</Layout>

<style>
  .projects-page {
    padding-top: 80px; /* Offset for fixed header */
  }

  /* Projects Hero */
  .projects-hero {
    padding: 100px 0 20px 0;
    text-align: center;
    background: linear-gradient(to bottom, var(--bg-surface-elevated) 0%, var(--bg-base) 100%);
  }

  .hero-content-wrapper {
    max-width: 800px;
    margin: 0 auto;
  }

  .projects-title {
    font-size: 3.5rem;
    margin-bottom: 20px;
    letter-spacing: -0.04em;
    line-height: 1.1;
  }

  .projects-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 992px) {
    .projects-title {
      font-size: 2.75rem;
    }
  }

  @media (max-width: 576px) {
    .projects-title {
      font-size: 2.25rem;
    }
  }
</style>
