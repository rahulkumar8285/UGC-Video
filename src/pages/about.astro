---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';

const seoTitle = 'About Rahul | Premium UGC Creator & Visual Strategist';
const seoDescription = 'Learn more about Rahul, a professional UGC creator specializing in high-converting video ads and brand photography. Direct channels and workflow guidelines.';
---

<Layout title={seoTitle} description={seoDescription}>
  <Header />

  <main class="about-page">
    <!-- Hero Banner -->
    <section class="about-hero">
      <div class="container hero-content-wrapper">
        <h1 class="about-title">The Mind Behind the <span class="text-gradient">Visuals</span></h1>
        <p class="about-subtitle">Helping high-growth ecommerce brands scale their ad accounts with scroll-stopping UGC assets.</p>
      </div>
    </section>

    <!-- Bio Section -->
    <section class="bio-section">
      <div class="container bio-container">
        <!-- Biography Content -->
        <div class="bio-content">
          <h2 class="bio-heading">Hi, I'm <span class="text-gradient">Rahul Kumar</span>. I create content that feels native and builds immediate trust.</h2>
          <p class="bio-text">
            If an ad looks like a traditional television ad, viewers scroll past it instantly. I specialize in building content that blends seamlessly into a user's TikTok or Instagram feed—feeling like a recommendation from a trusted friend, while utilizing solid conversion copywriting principles behind the scenes.
          </p>
          <p class="bio-text">
            Every video I shoot is backed by thorough competitor research and hook analysis. From scriptwriting to lighting, filming, and post-production editing, I deliver complete, ready-to-test assets in 2-3 business days.
          </p>

          <div class="highlights-grid">
            <div class="highlight-item">
              <span class="highlight-number text-gradient">3+</span>
              <span class="highlight-label">Years of Experience</span>
            </div>
            <div class="highlight-item">
              <span class="highlight-number text-gradient">100+</span>
              <span class="highlight-label">Deliverables Shipped</span>
            </div>
            <div class="highlight-item">
              <span class="highlight-number text-gradient">2-3</span>
              <span class="highlight-label">Day Turnaround</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Core Values Section -->
    <section class="values-section">
      <div class="container">
        <h2 class="section-title text-center">My Core <span class="text-gradient">Values</span></h2>
        <p class="section-subtitle text-center">Principles that guide how I research, script, and shoot every campaign.</p>

        <div class="values-grid">
          <!-- Card 1 -->
          <div class="value-card glass-panel">
            <div class="value-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="value-svg"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 class="value-title">Authenticity First</h3>
            <p class="value-desc">No over-polished scripts or fake acting. Real emotion and organic product testing build conversion trust.</p>
          </div>

          <!-- Card 2 -->
          <div class="value-card glass-panel">
            <div class="value-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="value-svg"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            </div>
            <h3 class="value-title">Data-Driven Hooks</h3>
            <p class="value-desc">Every hook is selected based on what is actively retaining viewers in your niche ad library.</p>
          </div>

          <!-- Card 3 -->
          <div class="value-card glass-panel">
            <div class="value-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="value-svg"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <h3 class="value-title">Reliable Turnaround</h3>
            <p class="value-desc">Ad testing moves fast. Standard delivery in 2-3 business days means your testing schedules never stall.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Details -->
    <Contact />
  </main>
</Layout>

<style>
  .about-page {
    padding-top: 80px; /* Offset for fixed header */
  }

  /* Hero Section */
  .about-hero {
    padding: 100px 0 60px 0;
    text-align: center;
    background: linear-gradient(to bottom, var(--bg-surface-elevated) 0%, var(--bg-base) 100%);
  }

  .hero-content-wrapper {
    max-width: 800px;
    margin: 0 auto;
  }

  .about-title {
    font-size: 3.5rem;
    margin-bottom: 20px;
    letter-spacing: -0.04em;
    line-height: 1.1;
  }

  .about-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Bio Section */
  .bio-section {
    padding: 80px 0;
    border-top: 1px solid var(--border-subtle);
  }

  .bio-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .bio-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .bio-heading {
    font-size: 2.25rem;
    letter-spacing: -0.03em;
    line-height: 1.2;
  }

  .bio-text {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 16px;
  }

  .highlight-item {
    display: flex;
    flex-direction: column;
    padding: 16px;
    background: var(--bg-surface-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .highlight-number {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 8px;
  }

  .highlight-label {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-weight: 600;
  }

  /* Values Section */
  .values-section {
    padding: 80px 0;
    border-top: 1px solid var(--border-subtle);
    background: linear-gradient(to bottom, var(--bg-base) 0%, var(--bg-surface-elevated) 100%);
  }

  .text-center {
    text-align: center;
  }

  .section-title {
    font-size: 3rem;
    margin-bottom: 16px;
    letter-spacing: -0.03em;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto 60px auto;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .value-card {
    padding: 32px;
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: var(--bg-surface);
  }

  .value-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-glow);
    box-shadow: 0 10px 25px rgba(79, 70, 229, 0.05);
  }

  .value-icon-box {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: rgba(79, 70, 229, 0.05);
    border: 1px solid rgba(79, 70, 229, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    color: var(--primary);
    box-shadow: 0 4px 10px var(--primary-glow);
  }

  .value-svg {
    width: 22px;
    height: 22px;
  }

  .value-title {
    font-size: 1.25rem;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }

  .value-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  @media (max-width: 992px) {

    .values-grid {
      grid-template-columns: 1fr;
      gap: 24px;
      max-width: 450px;
      margin: 0 auto;
    }

    .about-title {
      font-size: 2.75rem;
    }
  }

  @media (max-width: 576px) {
    .about-title {
      font-size: 2.25rem;
    }

    .bio-heading {
      font-size: 1.75rem;
    }

    .highlights-grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
