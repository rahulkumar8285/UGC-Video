---
---
<section class="hero-section">
  <div class="container hero-container-centered">
    <!-- Centered Copy & Stats -->
    <div class="hero-content-centered">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Rahul Kumar | UGC Creator & Brand Strategist
      </div>
      
      <h1 class="hero-title-centered">
        Stop-the-Scroll Content That <span class="text-gradient">Converts Views</span> Into Customers
      </h1>
      
      <p class="hero-description-centered">
        I craft high-impact, native-feeling short-form videos (TikTok, Reels, Shorts) that hook attention, build authentic trust, and drive measurable revenue for e-commerce brands.
      </p>
      
      <div class="hero-ctas-centered">
        <a href="#portfolio" class="btn-primary">View My Work</a>
        <a href="#contact" class="btn-secondary">Let's Collaborate</a>
      </div>
      
      <!-- Centered Stats -->
      <div class="hero-stats-centered">
        <div class="stat-item">
          <div class="stat-num text-gradient">15M+</div>
          <div class="stat-label">Views Generated</div>
        </div>
        <div class="stat-item">
          <div class="stat-num text-gradient">50+</div>
          <div class="stat-label">Brands Partnered</div>
        </div>
        <div class="stat-item">
          <div class="stat-num text-gradient">3.2x</div>
          <div class="stat-label">Average ROAS</div>
        </div>
      </div>
    </div>
    
    <!-- Video Showcase: 3 Mobile Phone Views Side-by-Side -->
    <div class="video-showcase-container">
      <div class="showcase-header">
        <h3 class="showcase-title">Active <span class="text-gradient">UGC Campaigns</span></h3>
        <p class="showcase-desc">Real campaigns running on TikTok, Instagram Reels, and YouTube Shorts.</p>
      </div>

      <div class="showcase-phones">
        <!-- Phone 1: Apparel/Cloth -->
        <div class="phone-frame glass-panel-elevated">
          <div class="phone-screen">
            <video 
              class="showcase-video" 
              autoplay 
              muted 
              loop 
              playsinline 
              preload="metadata"
              poster="/images/hero-ugc.jpg"
            >
              <source src="/portfolio/Cloth/project/Final-Output.mp4" type="video/mp4" />
            </video>
            <!-- Simulated Video Player Controls -->
            <div class="video-overlay">
              <div class="video-badge">
                <span class="live-dot"></span>
                APPAREL
              </div>
              
              <!-- Sidebar UI (Likes, Comments, Shares) -->
              <div class="player-sidebar">
                <div class="sidebar-action">
                  <span class="action-icon">❤</span>
                  <span class="action-count">14.8k</span>
                </div>
                <div class="sidebar-action">
                  <span class="action-icon">💬</span>
                  <span class="action-count">312</span>
                </div>
              </div>
              
              <!-- Bottom UI (Creator info, Caption) -->
              <div class="player-info">
                <div class="creator-header">
                  <div class="creator-avatar" style="background-image: url('/images/avatar.jpg');"></div>
                  <div class="creator-name">@apex.apparel</div>
                </div>
                <p class="video-caption">
                  Premium streetwear apparel showcase reels that capture lifestyle aesthetics. 🧥✨ #streetwear #ugc #fashionad
                </p>
                <div class="playback-bar"><div class="playback-progress" style="width: 65%;"></div></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Phone 2: Jewellery -->
        <div class="phone-frame glass-panel-elevated">
          <div class="phone-screen">
            <video 
              class="showcase-video" 
              autoplay 
              muted 
              loop 
              playsinline 
              preload="metadata"
              poster="/portfolio/artificial%20jewellery/Project-1/product-ref.avif"
            >
              <source src="/portfolio/artificial%20jewellery/Project-1/Final%20Export.mp4" type="video/mp4" />
            </video>
            <!-- Simulated Video Player Controls -->
            <div class="video-overlay">
              <div class="video-badge">
                <span class="live-dot"></span>
                JEWELLERY
              </div>
              
              <!-- Sidebar UI (Likes, Comments, Shares) -->
              <div class="player-sidebar">
                <div class="sidebar-action">
                  <span class="action-icon">❤</span>
                  <span class="action-count">38.4k</span>
                </div>
                <div class="sidebar-action">
                  <span class="action-icon">💬</span>
                  <span class="action-count">512</span>
                </div>
              </div>
              
              <!-- Bottom UI (Creator info, Caption) -->
              <div class="player-info">
                <div class="creator-header">
                  <div class="creator-avatar" style="background-image: url('/images/avatar.jpg');"></div>
                  <div class="creator-name">@luxe.aura</div>
                </div>
                <p class="video-caption">
                  Aesthetic close-ups of handcrafted gold jewellery for minimalist lovers. 💍💎 #goldjewelry #aesthetic #craftsmanship
                </p>
                <div class="playback-bar"><div class="playback-progress" style="width: 35%;"></div></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Phone 3: Massager -->
        <div class="phone-frame glass-panel-elevated">
          <div class="phone-screen">
            <video 
              class="showcase-video" 
              autoplay 
              muted 
              loop 
              playsinline 
              preload="metadata"
              poster="/portfolio/massager/project-1/Lifestyle%20Image%20v-3.png"
            >
              <source src="/portfolio/massager/project-1/Final-Rendor.mp4" type="video/mp4" />
            </video>
            <!-- Simulated Video Player Controls -->
            <div class="video-overlay">
              <div class="video-badge">
                <span class="live-dot"></span>
                WELLNESS
              </div>
              
              <!-- Sidebar UI (Likes, Comments, Shares) -->
              <div class="player-sidebar">
                <div class="sidebar-action">
                  <span class="action-icon">❤</span>
                  <span class="action-count">24.5k</span>
                </div>
                <div class="sidebar-action">
                  <span class="action-icon">💬</span>
                  <span class="action-count">287</span>
                </div>
              </div>
              
              <!-- Bottom UI (Creator info, Caption) -->
              <div class="player-info">
                <div class="creator-header">
                  <div class="creator-avatar" style="background-image: url('/images/avatar.jpg');"></div>
                  <div class="creator-name">@therarelief</div>
                </div>
                <p class="video-caption">
                  High-converting problem-solving demo of the smart muscle massager. 🔋💆‍♂️ #massager #recovery #wellnessad
                </p>
                <div class="playback-bar"><div class="playback-progress" style="width: 80%;"></div></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding-top: 150px;
    padding-bottom: 80px;
    position: relative;
    z-index: 1;
    overflow: hidden;
  }

  .hero-container-centered {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 80px;
  }

  .hero-content-centered {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 800px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: rgba(79, 70, 229, 0.05);
    border: 1px solid rgba(79, 70, 229, 0.15);
    border-radius: 100px;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--primary);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 24px;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background-color: var(--primary);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--primary-glow);
  }

  .hero-title-centered {
    font-size: 4rem;
    line-height: 1.1;
    margin-bottom: 24px;
    letter-spacing: -0.03em;
  }

  .hero-description-centered {
    font-size: 1.2rem;
    color: var(--text-secondary);
    margin-bottom: 40px;
    max-width: 680px;
  }

  .hero-ctas-centered {
    display: flex;
    gap: 16px;
    margin-bottom: 60px;
  }

  /* Centered Stats Section */
  .hero-stats-centered {
    display: flex;
    justify-content: center;
    gap: 64px;
    border-top: 1px solid var(--border-subtle);
    padding-top: 32px;
    width: 100%;
    max-width: 600px;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-num {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 6px;
  }

  .stat-label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Video Showcase Section */
  .video-showcase-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  .showcase-header {
    text-align: center;
  }

  .showcase-title {
    font-size: 2rem;
    margin-bottom: 8px;
  }

  .showcase-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
  }

  .showcase-phones {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    width: 100%;
    max-width: 1000px;
    justify-items: center;
  }

  /* Phone Mockup Styling */
  .phone-frame {
    width: 290px;
    height: 540px;
    border-radius: 36px;
    padding: 10px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 20px 40px -15px rgba(15, 23, 42, 0.08);
    background: rgba(255, 255, 255, 0.75);
    position: relative;
    overflow: hidden;
    transition: var(--transition-smooth);
  }

  .phone-frame:hover {
    transform: translateY(-8px);
    box-shadow: 0 25px 45px -10px rgba(79, 70, 229, 0.15);
    border-color: rgba(79, 70, 229, 0.2);
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    border-radius: 26px;
    overflow: hidden;
    background-color: #000;
    position: relative;
  }

  .showcase-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0) 45%, rgba(0,0,0,0.3) 100%);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 16px;
  }

  .video-badge {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 40px;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #fff;
  }

  .live-dot {
    width: 6px;
    height: 6px;
    background-color: var(--primary);
    border-radius: 50%;
    animation: blink 1.5s infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 1; }
  }

  /* Player Sidebar */
  .player-sidebar {
    position: absolute;
    right: 8px;
    bottom: 140px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    z-index: 2;
  }

  .sidebar-action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .action-icon {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255,255,255,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.95rem;
    color: #fff;
  }

  .action-count {
    font-size: 0.65rem;
    font-weight: 500;
    color: rgba(255,255,255,0.9);
  }

  /* Player Bottom Info */
  .player-info {
    z-index: 2;
    text-align: left;
  }

  .creator-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }

  .creator-avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background-size: cover;
    background-position: center;
    border: 1.5px solid var(--primary);
  }

  .creator-name {
    font-size: 0.75rem;
    font-weight: 700;
    color: #fff;
  }

  .video-caption {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.3;
    margin-bottom: 10px;
    white-space: normal;
  }

  .playback-bar {
    width: 100%;
    height: 3px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 2px;
    overflow: hidden;
  }

  .playback-progress {
    height: 100%;
    background-color: var(--primary);
    box-shadow: 0 0 6px var(--primary-glow);
  }

  @media (max-width: 992px) {
    .showcase-phones {
      gap: 20px;
    }
    
    .phone-frame {
      width: 240px;
      height: 450px;
    }

    .hero-title-centered {
      font-size: 3rem;
    }
  }

  @media (max-width: 768px) {
    .showcase-phones {
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      width: 100vw;
      padding: 0 24px 20px 24px;
      margin-left: -24px;
      margin-right: -24px;
      scrollbar-width: none;
      justify-content: flex-start;
      gap: 20px;
    }

    .showcase-phones::-webkit-scrollbar {
      display: none;
    }

    .phone-frame {
      scroll-snap-align: center;
      flex-shrink: 0;
      width: 280px;
      height: 520px;
    }
  }

  @media (max-width: 576px) {
    .hero-title-centered {
      font-size: 2.25rem;
    }
    
    .hero-ctas-centered {
      flex-direction: column;
      width: 100%;
      gap: 12px;
    }
    
    .hero-ctas-centered .btn-primary, .hero-ctas-centered .btn-secondary {
      width: 100%;
    }
    
    .hero-stats-centered {
      gap: 32px;
    }
    
    .stat-num {
      font-size: 1.75rem;
    }
  }
</style>
